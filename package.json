    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.38.0",
    "glob": "^13.0.6",
    "googleapis": "^171.4.0",
    "lucide-react": "^1.11.0",
    "mermaid": "^11.15.0",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.25",
    "prisma": "^6.19.3",
    "react": "19.2.4",
