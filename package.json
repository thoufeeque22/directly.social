{
  "name": "directly.social",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "tunnel": "cloudflared tunnel --url http://localhost:3000",
    "worker": "tsx --env-file=.env scripts/worker.ts",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "clear-activity": "npx tsx src/__tests__/scripts/clear-activity.ts",
    "cleanup:neon": "bash src/__tests__/scripts/cleanup-neon.sh",
    "cleanup:neon:force": "bash src/__tests__/scripts/cleanup-neon.sh --force",
    "notebook:package": "npx tsx scripts/notebook-bundle.ts",
    "prune-state": "npx tsx scripts/prune-state.ts",
    "state:update": "npx tsx scripts/state-manager.ts",
    "seed:e2e": "npx tsx src/__tests__/scripts/seed-e2e-user.ts",
    "seed:schedule": "npx tsx src/__tests__/scripts/seed-e2e-schedule.ts",
    "seed:whats-new": "npx tsx src/__tests__/scripts/seed-whats-new.ts",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:regression": "npx playwright test --grep @regression",
    "test:e2e:server": "NODE_ENV=test NEXT_DIST_DIR=.next-e2e npm run start -- -p 3005",
    "test:visual": "npx playwright test --grep @visual",
    "test:native": "maestro test .maestro/",
    "test:native:full": "bash scripts/mobile-test.sh",
    "mobile:ios": "open -a Simulator",
    "mobile:android": "~/Library/Android/sdk/emulator/emulator -avd $(~/Library/Android/sdk/emulator/emulator -list-avds | head -n 1) &",
    "mobile:dev": "bash scripts/mobile-dev.sh",
    "postinstall": "prisma generate"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@sentry/cli",
      "esbuild",
      "prisma",
      "sharp",
      "tree-sitter",
      "tree-sitter-json",
      "@tree-sitter-grammars/tree-sitter-yaml",
      "unrs-resolver",
      "core-js-pure",
      "@scarf/scarf"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
