generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                    String          @id @default(cuid())
  userId                String
  type                  String
  provider              String
  providerAccountId     String
  refresh_token         String?
  access_token          String?
  expires_at            Int?
  token_type            String?
  scope                 String?
  id_token              String?
  session_state         String?
  accountName           String?
  isDistributionEnabled Boolean         @default(true)
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenAuditLogs        TokenAuditLog[]

  @@unique([provider, providerAccountId])
}

model ByokCredential {
  id           String   @id @default(cuid())
  userId       String
  platform     String
  clientId     String
  clientSecret String
  redirectUri  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
}

model ByosConfig {
  id              String       @id @default(cuid())
  userId          String       @unique
  provider        ByosProvider
  bucketName      String
  endpoint        String?
  region          String?
  accessKeyId     String
  secretAccessKey String
  pathPrefix      String       @default("")
  keepFiles       Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GalleryAsset {
  id               String   @id @default(cuid())
  userId           String
  fileId           String   @unique
  fileName         String
  fileSize         BigInt?
  mimeType         String?
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  metadata         Json?
  processingStatus String?  @default("ready")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

model LaunchTask {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("pending")
  category    String   @default("Marketing")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, status])
}

model MetadataTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PlatformPreference {
  id         String  @id @default(cuid())
  userId     String
  platformId String
  isEnabled  Boolean @default(false)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platformId])
}

model PostActivity {
  id           String               @id @default(cuid())
  userId       String
  title        String
  description  String?
  videoFormat  String               @default("short")
  scheduledAt  DateTime?
  isPublished  Boolean              @default(false)
  stagedFileId String?
  createdAt    DateTime             @default(now())
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  platforms    PostPlatformResult[]
}

model PostPlatformResult {
  id              String      @id @default(cuid())
  postActivityId   String
  platform        String
  accountName     String?
  accountId       String?
  platformPostId  String?
  permalink       String?
  status          String      @default("success")
  errorMessage    String?
  resumableUrl    String?
  videoId         String?
  creationId      String?
  lastOffset      Int         @default(0)
  retryCount      Int         @default(0)
  lastRetryAt     DateTime?
  createdAt       DateTime    @default(now())
  optimizedFileId String?
  transcodeStatus String?     @default("skipped")
  metadata        Json?
  progress        Int         @default(0)
  postActivity     PostActivity @relation(fields: [postActivityId], references: [id], onDelete: Cascade)

  @@unique([postActivityId, platform, accountId], name: "postActivityId_platform_accountId")
}

model RoadmapTask {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("pending")
  priority    String   @default("High Priority")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([priority, status])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemMetric {
  id        String   @id @default(cuid())
  name      String
  value     Float
  timestamp DateTime @default(now())
}

model TokenAuditLog {
  id        String   @id @default(cuid())
  userId    String
  accountId String?
  action    String
  provider  String?
  reason    String?
  createdAt DateTime @default(now())
  account   Account? @relation(fields: [accountId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([action])
  @@index([createdAt])
  @@index([userId])
}

model UpdateLog {
  id             String           @id @default(cuid())
  version        String
  title          String
  description    String
  createdAt      DateTime         @default(now())
  seenBy UserSeenUpdate[]

  @@index([createdAt])
}

model User {
  id                   String               @id @default(cuid())
  name                 String?
  email                String?              @unique
  emailVerified        DateTime?
  image                String?
  preferredVideoFormat String               @default("short")
  preferredAIStyle     String               @default("Manual")
  preferredAIStyleMode String               @default("Smart")
  preferredAIProvider  String               @default("gemini")
  role                 Role                 @default(USER)
  accounts              Account[]
  byokCredentials       ByokCredential[]
  byosConfig           ByosConfig?
  galleryAssets         GalleryAsset[]
  metadataTemplates     MetadataTemplate[]
  platformPreferences   PlatformPreference[]
  postActivities          PostActivity[]
  sessions              Session[]
  tokenAuditLogs        TokenAuditLog[]
  seenUpdates       UserSeenUpdate[]
}
model UserSeenUpdate {
  id        String    @id @default(cuid())
  userId    String
  updateId  String
  seenAt    DateTime  @default(now())
  update    UpdateLog @relation(fields: [updateId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, updateId])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum ByosProvider {
  S3
  R2
}

enum Role {
  USER
  ADMIN
}
